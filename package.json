{
  "name": "agent-bridge",
  "displayName": "Agent Bridge",
  "description": "Bridge between external agents and VS Code's active editor context",
  "version": "0.1.0",
  "publisher": "agent-bridge",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentBridge.enableWorkspace",
        "title": "Agent Bridge: Enable for Current Workspace"
      },
      {
        "command": "agentBridge.disableWorkspace",
        "title": "Agent Bridge: Disable for Current Workspace"
      },
      {
        "command": "agentBridge.copySessionFilePath",
        "title": "Agent Bridge: Copy Session File Path"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@10.32.1"
}
